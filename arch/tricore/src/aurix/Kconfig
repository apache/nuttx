menu "AURIX peripheral selection"

config TC4X_GPIO_ACCESS_GROUP
	int "TC4X port access group"
	default 0
	range 0 7
	depends on ARCH_CHIP_FAMILY_TC4X
	---help---
		Access group used to drive the per-port PORTPROT register.

endmenu
