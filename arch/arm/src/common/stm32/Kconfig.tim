config STM32_TIM2_CH4OUT
	bool "TIM2 Channel 4 Output"
	depends on STM32_TIM2_PWM
	depends on STM32_PWM_MULTICHAN || (STM32_TIM2_CHANNEL = 4 && STM32_HAVE_TIM_PWM_SINGLECHAN)
	depends on !STM32_PWM_MULTICHAN || STM32_TIM2_CHANNEL4 || (STM32_COMMON_L5_U5 && STM32_TIM2_CHANNEL5)
