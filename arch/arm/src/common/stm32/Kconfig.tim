config STM32_TIM2_CH4MODE
	int "TIM2 Channel 4 Mode"
	depends on STM32_TIM2_PWM && STM32_PWM_MULTICHAN
	depends on STM32_TIM2_CHANNEL4 || (STM32_COMMON_L5_U5 && STM32_TIM2_CHANNEL5)
	default 0 if STM32_HAVE_TIM_PWM_CHMODE_LIMITED
