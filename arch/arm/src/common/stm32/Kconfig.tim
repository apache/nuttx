config STM32_TIM2_CH3OUT
	bool "TIM2 Channel 3 Output"
	depends on STM32_TIM2_PWM
	depends on (STM32_PWM_MULTICHAN && STM32_TIM2_CHANNEL3) || (!STM32_PWM_MULTICHAN && STM32_TIM2_CHANNEL = 3 && STM32_HAVE_TIM_PWM_SINGLECHAN)
