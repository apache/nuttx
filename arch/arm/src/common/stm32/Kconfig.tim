	---help---
		Reserve timer 17 for use by the capture driver.

config STM32_TIM15_CLOCK
	int "TIM15 capture frequency (Hz)"
	depends on ARCH_CHIP_STM32H7 && STM32_TIM15_CAP
	default 100000
	---help---
		This clock frequency determines the timer's counting rate.

config STM32_TIM16_CLOCK
	int "TIM16 capture frequency (Hz)"
	depends on ARCH_CHIP_STM32H7 && STM32_TIM16_CAP
	default 100000
	---help---
