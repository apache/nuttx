		Enables channel 2 output.

config STM32_TIM2_CHANNEL3
	bool "TIM2 Channel 3"
	depends on STM32_TIM2_PWM && STM32_PWM_MULTICHAN
	---help---
		Enables channel 3.

config STM32_TIM2_CH3MODE
	int "TIM2 Channel 3 Mode"
	depends on STM32_TIM2_PWM && STM32_PWM_MULTICHAN && STM32_TIM2_CHANNEL3
	default 0 if STM32_HAVE_TIM_PWM_CHMODE_LIMITED
