config STM32_TIM1_CAP
	bool "TIM1 Capture"
	depends on STM32_HAVE_IP_TIMERS && STM32_TIM && STM32_TIM1 || (STM32_COMMON_F7_H7_H5) && STM32_TIM1 || STM32_COMMON_L4_L5_U5 && STM32_HAVE_TIM1
	select STM32_CAP if STM32_HAVE_IP_TIMERS && STM32_TIM && STM32_TIM1
	select STM32_TIMX_CAP if ARCH_CHIP_STM32H7 && STM32_TIM1
	---help---
