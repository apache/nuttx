config STM32_QENCODER_FILTER
	bool "Enable filtering on STM32 QEncoder input"
	depends on STM32_QENCODER_MAIN || STM32_QENCODER_F0
	default y
	---help---
		Enable input filtering on quadrature encoder channels to reduce noise.

config STM32_TIM16_CH1NOUT
	bool "TIM16 Channel 1 Complementary Output"
	depends on (STM32_HAVE_IP_TIMERS || STM32_COMMON_L4_L5_U5) && STM32_TIM16_PWM && STM32_PWM_MULTICHAN && STM32_TIM16_CHANNEL1 && STM32_TIM16_CH1OUT
