	depends on STM32_TIM2_PWM
	depends on (STM32_PWM_MULTICHAN && STM32_TIM2_CHANNEL2) || (!STM32_PWM_MULTICHAN && STM32_TIM2_CHANNEL = 2 && STM32_HAVE_TIM_PWM_SINGLECHAN)
