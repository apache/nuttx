	depends on STM32_HAVE_SAI1

config STM32_SAI1_A
	bool "SAI1 Block A"
	depends on (ARCH_CHIP_STM32F7 || ARCH_CHIP_STM32L4) && STM32_SAI1
	select AUDIO
	select I2S
	select SCHED_HPWORK
	select STM32_SAI

config STM32_SAI1_B
	bool "SAI1 Block B"
	depends on (ARCH_CHIP_STM32F7 || ARCH_CHIP_STM32L4) && STM32_SAI1
	select AUDIO
	select I2S
	select SCHED_HPWORK
	select STM32_SAI

config STM32_SAI2
	bool "SAI2"
	depends on STM32_HAVE_SAI2

config STM32_SAI2_A
	bool "SAI2 Block A"
	depends on (ARCH_CHIP_STM32F7 || ARCH_CHIP_STM32L4) && STM32_SAI2
	select AUDIO
	select I2S
	select SCHED_HPWORK
	select STM32_SAI

config STM32_SAI2_B
	bool "SAI2 Block B"
	depends on (ARCH_CHIP_STM32F7 || ARCH_CHIP_STM32L4) && STM32_SAI2
	select AUDIO
	select I2S
	select SCHED_HPWORK
	select STM32_SAI

