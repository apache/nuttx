# IPCC peripherals

config STM32_IPCC
	bool "IPCC"
	depends on STM32_HAVE_IPCC
	select IPCC if ARCH_CHIP_STM32WL5
	---help---
		IPCC - Inter Processor Communication Controller. A very simple
		character device stream driver to exchange data between
		CM0 and CM4.

config STM32_HSEM
	bool "Hardware semaphore"
	depends on STM32_HAVE_HSEM
