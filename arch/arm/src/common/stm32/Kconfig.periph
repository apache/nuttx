# Display peripherals

config STM32_LCD
	bool "Segment LCD"
	depends on STM32_HAVE_LCD
	select USBDEV if STM32_COMMON_F0_L0_G0_C0 && STM32_HAVE_LCD

config STM32_DSIHOST
	bool "DSIHOST"
	depends on STM32_HAVE_DSIHOST
	---help---
		The DSI Host is a dedicated peripheral for interfacing with MIPI DSI
		compliant displays.

config STM32_LTDC
	bool "LTDC"
	depends on STM32_HAVE_LTDC
	select FB
	---help---
		The STM32 LTDC is an LCD-TFT Display Controller available on
		the STM32F429 and STM32F439 devices.  It is a standard parallel
		video interface (HSYNC, VSYNC, etc.) for controlling TFT
		LCD displays.

endmenu # STM32 Peripheral Support
