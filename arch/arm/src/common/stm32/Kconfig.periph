	bool "TIM15"
	depends on STM32_HAVE_TIM15
	select STM32_TIM

config STM32_TIM16
	bool "TIM16"
	depends on STM32_HAVE_TIM16
	select STM32_TIM

config STM32_TIM17
	bool "TIM17"
	depends on STM32_HAVE_TIM17
	select STM32_TIM

config STM32_LPTIM2
