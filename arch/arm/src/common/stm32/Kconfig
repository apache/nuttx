	depends on (STM32_COMMON_LEGACY && STM32_ADC && STM32_ADC3 && STM32_HAVE_IP_ADC_V1) || (ARCH_CHIP_STM32F7 && STM32_ADC && STM32_ADC3)
	default STM32_ADC3_DMA

config STM32_ADC3_DMA_CFG
	int "ADC3 DMA configuration"
	depends on STM32_COMMON_LEGACY && STM32_ADC && STM32_ADC3_DMA && !STM32_HAVE_IP_ADC_V1_BASIC || (ARCH_CHIP_STM32F7 || ARCH_CHIP_STM32L4) && STM32_ADC && STM32_ADC3_DMA
	default 1 if ARCH_CHIP_STM32L4
	default 0
	range 0 1
	---help---
		0 - ADC3 DMA in One Shot Mode, 1 - ADC3 DMA in Circular Mode

config STM32_ADC3_DMA_BATCH
	int "ADC3 DMA number of conversions"
	depends on (STM32_COMMON_LEGACY || STM32_COMMON_F7_H7 || ARCH_CHIP_STM32L4) && STM32_ADC && STM32_ADC3 && STM32_ADC3_DMA
	default 1
	---help---
		This option allows you to select the number of regular group conversions
		that will trigger a DMA callback transerring data to the upper-half driver.
		By default, this value is 1, which means that data is transferred after
		each group conversion.

