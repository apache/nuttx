	bool "Do not disqualify DMA capability based on cache alignment"
	depends on STM32_COMMON_F7_H7 && STM32_DMACAPABLE && ARMV7M_DCACHE && !ARMV7M_DCACHE_WRITETHROUGH
	---help---
