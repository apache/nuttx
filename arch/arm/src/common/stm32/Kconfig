	select STM32_HAVE_ADC3_DMA if STM32_COMMON_LEGACY && STM32_HAVE_ADC3 && (STM32_DMA2 || STM32_DMAMUX)
	select STM32_HAVE_ADC3_DMA if ARCH_CHIP_STM32F7 && STM32_DMA2

