config USART1_RXDMA
	bool
	depends on STM32_USART1 && USART1_SERIALDRIVER && STM32_USART1_HAVE_RXDMA
	---help---
	In high data rate usage, Rx DMA may eliminate Rx overrun errors

config USART1_TXDMA
	bool
	depends on STM32_USART1 && USART1_SERIALDRIVER && STM32_USART1_HAVE_TXDMA
	---help---
	In high data rate usage, Tx DMA may reduce CPU load

